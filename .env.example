# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/oms?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/oms

# NextAuth
NEXTAUTH_SECRET=your-secret-key
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_NAME=OMS
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HIDE_API_SYNC=false

# Naver Commerce API (스마트스토어 주문 동기화)
NAVER_CLIENT_ID=your-commerce-client-id
NAVER_CLIENT_SECRET=your-commerce-client-secret

# Naver Search API (키워드 순위 조회)
NAVER_SEARCH_CLIENT_ID=your-search-client-id
NAVER_SEARCH_CLIENT_SECRET=your-search-client-secret
NAVER_STORE_NAME=your-store-name
