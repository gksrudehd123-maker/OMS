generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(STAFF)
  allowedChannels String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  uploads         Upload[]

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id              String    @id @default(cuid())
  name            String
  optionInfo      String    @default("")
  productKey      String    @unique
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  costPrice       Decimal?  @db.Decimal(12, 2)
  sellingPrice    Decimal?  @db.Decimal(12, 2)
  feeRate         Decimal?  @db.Decimal(5, 2)
  shippingCost    Decimal   @default(0) @db.Decimal(10, 2)
  freeShippingMin Decimal?  @db.Decimal(10, 2)
  couponDiscount  Decimal?  @db.Decimal(10, 2)
  fulfillmentFee  Decimal?  @db.Decimal(10, 2)
  memo            String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]
  dailySales      DailySales[]

  @@index([name])
  @@map("products")
}

model Channel {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  feeRate   Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders     Order[]
  uploads    Upload[]
  adCosts    AdCost[]
  dailySales DailySales[]

  @@map("channels")
}

model Upload {
  id           String   @id @default(cuid())
  fileName     String
  channelId    String
  channel      Channel  @relation(fields: [channelId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  totalRows    Int      @default(0)
  successRows  Int      @default(0)
  errorRows    Int      @default(0)
  errors       Json?
  createdAt    DateTime @default(now())
  orders       Order[]
  dailySales   DailySales[]

  @@index([createdAt])
  @@map("uploads")
}

model Order {
  id                 String   @id @default(cuid())
  productOrderNumber String
  orderNumber        String
  orderDate          DateTime
  orderStatus        String
  deliveryAttribute  String?
  fulfillmentCompany String?
  claimStatus        String?
  quantityClaim      String?
  channelProductId   String?
  productName        String
  optionInfo         String   @default("")
  quantity           Int
  buyerName          String?
  buyerId            String?
  recipientName      String?
  subscriptionRound  String?
  subscriptionSeq    String?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productOrderNumber, channelId])
  @@index([orderDate])
  @@index([orderNumber])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("orders")
}

model AdCost {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  date      DateTime @db.Date
  cost      Decimal  @db.Decimal(12, 2)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, date])
  @@index([date])
  @@index([channelId])
  @@map("ad_costs")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model GeneratedReport {
  id         String   @id @default(cuid())
  type       String   // "weekly" | "monthly"
  periodFrom DateTime @db.Date
  periodTo   DateTime @db.Date
  reportData Json     // 리포트 데이터 스냅샷 (kpi, channelData, dailyData, productData)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("generated_reports")
}

model DailySales {
  id                      String   @id @default(cuid())
  date                    DateTime @db.Date
  optionId                String
  exposureProductId       String?
  optionName              String
  productType             String?
  categoryName            String?
  itemWinnerRate          Decimal? @db.Decimal(5, 2)
  salesAmount             Decimal  @db.Decimal(12, 2)
  salesQuantity           Int
  totalAmount             Decimal? @db.Decimal(12, 2)
  totalQuantity           Int?
  cancelAmount            Decimal? @db.Decimal(12, 2)
  cancelQuantity          Int?
  immediateCancelQuantity Int?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, optionId, channelId])
  @@index([date])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("daily_sales")
}
