generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  uploads   Upload[]

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id              String    @id @default(cuid())
  name            String
  optionInfo      String    @default("")
  productKey      String    @unique
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  costPrice       Decimal?  @db.Decimal(12, 2)
  sellingPrice    Decimal?  @db.Decimal(12, 2)
  shippingCost    Decimal   @default(0) @db.Decimal(10, 2)
  freeShippingMin Decimal?  @db.Decimal(10, 2)
  memo            String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]

  @@index([name])
  @@map("products")
}

model Channel {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  feeRate   Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  uploads   Upload[]

  @@map("channels")
}

model Upload {
  id           String   @id @default(cuid())
  fileName     String
  channelId    String
  channel      Channel  @relation(fields: [channelId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  totalRows    Int      @default(0)
  successRows  Int      @default(0)
  errorRows    Int      @default(0)
  errors       Json?
  createdAt    DateTime @default(now())
  orders       Order[]

  @@index([createdAt])
  @@map("uploads")
}

model Order {
  id                 String   @id @default(cuid())
  productOrderNumber String
  orderNumber        String
  orderDate          DateTime
  orderStatus        String
  deliveryAttribute  String?
  fulfillmentCompany String?
  claimStatus        String?
  quantityClaim      String?
  channelProductId   String?
  productName        String
  optionInfo         String   @default("")
  quantity           Int
  buyerName          String?
  buyerId            String?
  recipientName      String?
  subscriptionRound  String?
  subscriptionSeq    String?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productOrderNumber, channelId])
  @@index([orderDate])
  @@index([orderNumber])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("orders")
}
