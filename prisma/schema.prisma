generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(STAFF)
  allowedChannels String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  uploads         Upload[]

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]

  @@map("categories")
}

model Product {
  id              String    @id @default(cuid())
  name            String
  optionInfo      String    @default("")
  productKey      String    @unique
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  costPrice       Decimal?  @db.Decimal(12, 2)
  sellingPrice    Decimal?  @db.Decimal(12, 2)
  feeRate         Decimal?  @db.Decimal(5, 2)
  shippingCost    Decimal   @default(0) @db.Decimal(10, 2)
  freeShippingMin Decimal?  @db.Decimal(10, 2)
  couponDiscount  Decimal?  @db.Decimal(10, 2)
  fulfillmentFee  Decimal?  @db.Decimal(10, 2)
  brand           String?               // 브랜드 (방짜, 웰스파, 카모도)
  brandCategory   String?               // 브랜드 내 세부 카테고리 (배터리, 기포기 등)
  brandNone       Boolean   @default(false) // true: 해당사항 없음 (분류 대상 아님)
  memo            String?
  isActive        Boolean   @default(true)
  storeProductId  String?               // 네이버 쇼핑 상품 ID (키워드 순위 매칭용)
  thumbnailUrl    String?               // 네이버 쇼핑 썸네일 URL
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders              Order[]
  dailySales          DailySales[]
  coupangDailyMetrics CoupangDailyMetrics[]
  keywords            ProductKeyword[]
  adBudgets           ProductAdBudget[]

  @@index([name])
  @@map("products")
}

model Channel {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  feeRate   Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders              Order[]
  uploads             Upload[]
  adCosts             AdCost[]
  dailySales          DailySales[]
  coupangDailyMetrics CoupangDailyMetrics[]
  adBudgets           ProductAdBudget[]

  @@map("channels")
}

model Upload {
  id           String   @id @default(cuid())
  fileName     String
  channelId    String
  channel      Channel  @relation(fields: [channelId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  totalRows    Int      @default(0)
  successRows  Int      @default(0)
  errorRows    Int      @default(0)
  errors       Json?
  createdAt    DateTime @default(now())
  orders              Order[]
  dailySales          DailySales[]
  coupangDailyMetrics CoupangDailyMetrics[]

  @@index([createdAt])
  @@map("uploads")
}

model Order {
  id                 String   @id @default(cuid())
  productOrderNumber String
  orderNumber        String
  orderDate          DateTime @db.Date
  orderStatus        String
  deliveryAttribute  String?
  fulfillmentCompany String?
  claimStatus        String?
  quantityClaim      String?
  channelProductId   String?
  productName        String
  optionInfo         String   @default("")
  quantity           Int
  buyerName          String?
  buyerId            String?
  recipientName      String?
  subscriptionRound  String?
  subscriptionSeq    String?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productOrderNumber, channelId])
  @@index([orderDate])
  @@index([orderNumber])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("orders")
}

model AdCost {
  id        String   @id @default(cuid())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  date      DateTime @db.Date
  cost      Decimal  @db.Decimal(12, 2)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, date])
  @@index([date])
  @@index([channelId])
  @@map("ad_costs")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model GeneratedReport {
  id         String   @id @default(cuid())
  type       String   // "weekly" | "monthly"
  periodFrom DateTime @db.Date
  periodTo   DateTime @db.Date
  reportData Json     // 리포트 데이터 스냅샷 (kpi, channelData, dailyData, productData)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@map("generated_reports")
}

model DailySales {
  id                      String   @id @default(cuid())
  date                    DateTime @db.Date
  optionId                String
  exposureProductId       String?
  optionName              String
  productType             String?
  categoryName            String?
  itemWinnerRate          Decimal? @db.Decimal(5, 2)
  salesAmount             Decimal  @db.Decimal(12, 2)
  salesQuantity           Int
  totalAmount             Decimal? @db.Decimal(12, 2)
  totalQuantity           Int?
  cancelAmount            Decimal? @db.Decimal(12, 2)
  cancelQuantity          Int?
  immediateCancelQuantity Int?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, optionId, channelId])
  @@index([date])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("daily_sales")
}

model CoupangDailyMetrics {
  id                      String   @id @default(cuid())
  date                    DateTime @db.Date
  optionId                String
  registeredProductId     String?               // 등록상품ID
  optionName              String
  productName             String
  categoryName            String?
  salesMethod             String?               // 판매방식 (판매자배송 등)
  salesAmount             Decimal  @db.Decimal(12, 2) // 매출(원)
  orderCount              Int                   // 주문 건수
  salesQuantity           Int                   // 판매량
  visitors                Int?                  // 방문자
  views                   Int?                  // 조회
  cart                    Int?                  // 장바구니
  conversionRate          Decimal? @db.Decimal(5, 2)  // 구매전환율(%)
  itemWinnerRate          Decimal? @db.Decimal(5, 2)  // 아이템위너 비율(%)
  totalAmount             Decimal? @db.Decimal(12, 2) // 총 매출(원)
  totalQuantity           Int?                  // 총 판매수
  cancelAmount            Decimal? @db.Decimal(12, 2) // 총 취소 금액(원)
  cancelQuantity          Int?                  // 총 취소된 상품수
  immediateCancelQuantity Int?                  // 즉시 취소된 상품수

  productId String
  product   Product @relation(fields: [productId], references: [id])
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id])
  uploadId  String
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, optionId, channelId])
  @@index([date])
  @@index([productId])
  @@index([channelId])
  @@index([uploadId])
  @@map("coupang_daily_metrics")
}

// ============================================================
// CS(A/S) 관리
// ============================================================

model CSRecord {
  id              String    @id @default(cuid())
  consultDate     DateTime  @db.Date              // 상담날짜
  purchaseDate    DateTime? @db.Date              // 제품구입일자
  status          String    @default("교환요청")    // 교환요청|안내완료|진행 중|연락처없음|미입고
  receivedDate    DateTime? @db.Date              // 제품입고날짜
  customerName    String                          // 고객명
  productName     String                          // 제품명
  consultNote     String?                         // A/S 내용 및 상담내용
  receivedProduct String?                         // 입고된 제품
  serviceProgress String?                         // A/S 진행상황
  shippingDate    DateTime? @db.Date              // 출고날짜
  customerAddress String?                         // 고객주소
  customerPhone   String                          // 전화번호
  chargeType      String    @default("유상")       // 유상|무료
  repairCost      Int?                            // 수리비용
  trackingNumber  String?                         // 배송번호
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([consultDate])
  @@index([status])
  @@index([customerName])
  @@map("cs_records")
}

// ============================================================
// CS 상품 카탈로그 (고객 관리용)
// ============================================================

model CSProduct {
  id          String   @id @default(cuid())
  name        String                          // 상품명
  brand       String                          // 브랜드 (방짜/웰스파/카모도)
  price       Int?                            // 판매가
  imageUrl    String?                         // 메인 이미지 URL
  storeUrl    String?                         // 스마트스토어 링크
  description String?                         // 제품 설명 (스펙, 사용법 등)
  sortOrder   Int      @default(0)            // 정렬 순서
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts   CSProductPart[]
  faqs    CSProductFAQ[]
  options CSProductOption[]

  @@index([brand])
  @@map("cs_products")
}

model CSProductOption {
  id        String    @id @default(cuid())
  productId String
  product   CSProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String // 옵션명 (예: 단품, 싱글세트, 더블세트)
  price     Int? // 옵션 가격
  contents  String[] // 포함 구성품 목록 (예: ["배터리 1개", "가방 1개", "저속충전기", "케이블"])
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([productId])
  @@map("cs_product_options")
}

model CSProductPart {
  id          String    @id @default(cuid())
  productId   String
  product     CSProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String // 구성품명
  price       Int? // 개별 가격
  storeUrl    String? // 개별 구매 링크
  imageUrl    String? // 구성품 이미지
  description String? // 스펙/설명 (freeform)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([productId])
  @@map("cs_product_parts")
}

model CSProductFAQ {
  id        String   @id @default(cuid())
  productId String
  product   CSProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  question  String                            // 질문
  answer    String                            // 답변
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("cs_product_faqs")
}

// ============================================================
// 메시지 템플릿
// ============================================================

model MessageTemplate {
  id        String   @id @default(cuid())
  title     String                          // 템플릿 제목
  body      String                          // 본문 ({{변수명}} 포함)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("message_templates")
}

// ============================================================
// 감사 로그 (Audit Log)
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?  // 삭제된 사용자 추적용
  action    String   // CREATE, UPDATE, DELETE
  target    String   // 모델명 (Product, Channel, User 등)
  targetId  String?  // 대상 레코드 ID
  summary   String   // 사람이 읽을 수 있는 요약 ("상품 '온열복대' 원가 수정")
  changes   Json?    // 변경 전후 { field: { from, to } }
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([target])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// 키워드 순위 추적 (Phase 9.5)
// ============================================================

model ProductKeyword {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  keyword   String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  ranks     KeywordRank[]

  @@unique([productId, keyword])
  @@index([productId])
  @@map("product_keywords")
}

model KeywordRank {
  id        String   @id @default(cuid())
  keywordId String
  keyword   ProductKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  rank      Int?     // 순위 (null이면 100위 밖)
  page      Int?     // 몇 페이지
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([keywordId, date])
  @@index([keywordId])
  @@index([date])
  @@map("keyword_ranks")
}

// ============================================================
// 상품별 광고 예산 (광고 손익분기)
// ============================================================

model ProductAdBudget {
  id        String   @id @default(cuid())
  month     String   // "2026-03" 형식
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  adCost    Decimal  @db.Decimal(12, 2)
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, channelId, productId])
  @@index([month])
  @@index([productId])
  @@index([channelId])
  @@map("product_ad_budgets")
}
